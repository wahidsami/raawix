# Raawi X - Environment Variables Configuration
# Copy this file to .env and update with your values.
# DO NOT commit .env to version control.
#
# Scanner app: copy to apps/scanner/.env (so the scanner process and Prisma find it).
# If you run the scanner from repo root, you can use a .env at root instead.

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/raawix?schema=public

# Required only for `prisma migrate dev` (local dev). Not used by `prisma migrate deploy`.
# Use a dedicated empty DB (e.g. raawix_shadow). See docs/PRISMA_MIGRATE.md.
SHADOW_DATABASE_URL=postgresql://user:password@localhost:5432/raawix_shadow?schema=public

# ============================================
# Server Configuration
# ============================================
PORT=3001
NODE_ENV=development
REPORT_UI_ORIGIN=http://localhost:5173

# ============================================
# Rate Limiting (Production Scalability)
# ============================================
# Default rate limit for public/unauthenticated users
RATE_LIMIT_MAX=200

# Rate limit for authenticated users (higher for production)
RATE_LIMIT_AUTH_MAX=1000

# Rate limit for scan operations (heavy operations)
RATE_LIMIT_SCAN_MAX=10

# Rate limit for read operations
RATE_LIMIT_READ_MAX=500

# ============================================
# Security
# ============================================
JWT_SECRET=replace-with-a-strong-random-secret
JWT_EXPIRES_IN=7d
API_KEY=replace-with-a-strong-random-api-key

# ============================================
# User emails and password reset (optional)
# ============================================
# If RESEND_API_KEY is set, welcome and reset-password emails are sent via Resend.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
PASSWORD_RESET_EXPIRY_MS=3600000
RATE_LIMIT_FORGOT_PASSWORD_MAX=5

# ============================================
# Scanner Configuration
# ============================================
MAX_CONCURRENT_SCANS=5
MAX_PAGES_HARD_LIMIT=200
MAX_RUNTIME_MS=600000
SCAN_RETENTION_ENABLED=true
SCAN_RETENTION_DAYS=7

# ============================================
# Interaction Agent (Phase 0 – default OFF)
# ============================================
AGENT_ENABLED=false
AGENT_MAX_STEPS=50
AGENT_MAX_MS=10000
AGENT_PROBES_ENABLED=false

# ============================================
# OpenAI & Agent Analyst (Phase 3 – default OFF)
# ============================================
OPENAI_ENABLED=false
OPENAI_API_KEY=
# Model for analyst; gpt-4o-mini is a future optional upgrade (vision/multimodal).
OPENAI_MODEL=gpt-4.1-mini
AGENT_ANALYST_ENABLED=false
AGENT_ANALYST_MAX_PAGES=10
AGENT_ANALYST_MAX_ISSUES=20
AGENT_ANALYST_CACHE_TTL_MS=604800000

# ============================================
# Vision & AI (Gemini)
# ============================================
VISION_ENABLED=true
VISION_OCR_ENABLED=false
GEMINI_ENABLED=false
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_CHARS=4000
GEMINI_MAX_IMAGE_BYTES=10485760
GEMINI_MAX_IMAGES_PER_SCAN=50

# ============================================
# CORS & Origins
# ============================================
WIDGET_ORIGINS=http://localhost:4173,http://localhost:4174,http://localhost:3000
ALLOW_LOCALHOST=false
ALLOWED_PORTS=80,443

# ============================================
# Output & Storage
# ============================================
OUTPUT_DIR=./output
AUDIT_LOG_DIR=./logs
AUDIT_LOGGING=true

# ============================================
# Concurrency (Production)
# ============================================
MAX_CONCURRENT_REQUESTS=5

# ============================================
# Polling Configuration (Client-side)
# ============================================
# These are used by the frontend polling strategy
POLLING_BASE_INTERVAL=5000
POLLING_MAX_INTERVAL=30000
POLLING_BACKOFF_MULTIPLIER=1.5
