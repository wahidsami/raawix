{
  "name": "@raawi-x/scanner",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -b && node ./scripts/copy-static-assets.mjs",
    "type-check": "tsc -b --noEmit",
    "lint": "eslint src --ext .ts",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "db:generate": "prisma generate",
    "db:migrate": "node scripts/check-db.js && prisma migrate dev --name init",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@pdf-lib/fontkit": "1.1.1",
    "@raawi-x/core": "workspace:*",
    "@raawi-x/report": "workspace:*",
    "@raawi-x/rules": "workspace:*",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsdom": "^23.0.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "openai": "^6.17.0",
    "pdf-lib": "^1.17.1",
    "playwright": "^1.40.0",
    "resend": "^4.0.0",
    "tesseract.js": "^5.0.4",
    "xml2js": "^0.6.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@prisma/client": "^6.19.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsdom": "^21.1.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.10.0",
    "@types/xml2js": "^0.4.14",
    "@vitest/ui": "^1.0.0",
    "prisma": "^6.19.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.2",
    "vitest": "^1.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}